{% import '_includes/forms' as forms %}

{% if selectableSourceGroups|length %}
	{% set sourceIdsInput %}
		{# Unchecking every box posts an empty value, which is stored as "include every one". #}
		{{ hiddenInput('sourceIds', '') }}

		{% for group in selectableSourceGroups %}
			{% if group.heading %}
				<h6 class="pf-source-group">{{ group.heading }}</h6>
			{% endif %}
			<div class="checkbox-group">
				{% for option in group.options %}
					{{ forms.checkbox({
						name: 'sourceIds[]',
						label: option.label,
						value: option.value,
						checked: option.value in feed.sourceIds,
						disabled: readOnly,
					}) }}
				{% endfor %}
			</div>
		{% endfor %}
	{% endset %}

	{# A failed save reports the same sources as an error, so the warning is only for the unsaved feed. #}
	{{ forms.field({
		label: (feed.source == 'entries' ? 'feed.entryTypesLabel' : 'feed.productTypesLabel')|t('product-feeds'),
		instructions: 'feed.sourceIdsInstructions'|t('product-feeds'),
		id: 'sourceIds',
		errors: feed.getErrors('sourceIds'),
		warning: sourcesWithoutUrls and not feed.hasErrors('sourceIds')
			? 'error.sourcesWithoutUrls'|t('product-feeds', { names: sourcesWithoutUrls|join(', ') }),
	}, sourceIdsInput) }}
{% else %}
	<p class="error">{{ 'error.noSourcesWithUrls'|t('product-feeds') }}</p>
{% endif %}
