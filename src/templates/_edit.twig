{% extends '_layouts/cp' %}
{% import '_includes/forms' as forms %}

{% do view.registerTranslations('product-feeds', [
	'imageTest.belowMinimum',
	'imageTest.meetsMinimum',
	'imageTest.notAnImage',
]) %}

{% set readOnly = not canEdit %}
{% set title = feed.id ? feed.name : 'feed.new'|t('product-feeds') %}
{% set fullPageForm = not readOnly %}
{% set crumbs = [
	{ label: 'nav.productFeeds'|t('product-feeds'), url: url('product-feeds', { site: site.handle }) },
] %}

{% if readOnly %}
	{% set contentNotice = readOnlyNotice() %}
{% endif %}

{# A feed belongs to the site it was created on, so the crumb names it rather than offering a switch. #}
{% if craft.app.getIsMultiSite() %}
	{% set crumbs = crumbs|merge([{ id: 'site-crumb', icon: 'world', label: site.name|t('site') }]) %}
{% endif %}

{% set tabs = {
	settings: { label: 'edit.settingsTab'|t('product-feeds'), url: '#settings' },
	mapping: { label: 'edit.mappingTab'|t('product-feeds'), url: '#mapping' },
} %}

{% set imageAttribute = spec.imageAttribute() %}

{# The initial state of the image fields. `refreshImageFields()` in feed-edit.js applies the same rule
   on every change, so the two have to agree or the fields flicker on load. #}
{% set usingNamedCraftTransform = feed.imageEngine == 'craft' and feed.imageTransform %}
{% set hideImageSize = feed.imageEngine == 'none' or usingNamedCraftTransform %}

{% block actionButton %}
	<div class="btngroup">
		{% if not readOnly %}
			<button type="submit" class="btn submit">{{ 'Save'|t('app') }}</button>
		{% endif %}
		{% if feed.id and (canBuild or not readOnly) %}
			<button type="button" class="btn submit menubtn" aria-label="{{ 'Actions'|t('app') }}"></button>
			<div class="menu">
				<ul>
					{% if canBuild %}
						<li>
							{# Not a `formsubmit`: a user with Build but not Edit gets a read-only page, which has no
							   form for one to submit. The JS posts the action itself. #}
							<button id="build-now" class="menu-item" type="button" data-feed-id="{{ feed.id }}">
								{{ 'feed.buildNow'|t('product-feeds') }}
							</button>
						</li>
					{% endif %}
					{% if not readOnly %}
						<li>
							<button class="menu-item formsubmit" type="button"
								data-action="product-feeds/feeds/duplicate"
								data-param="feedId" data-value="{{ feed.id }}">
								{{ 'feed.duplicate'|t('product-feeds') }}
							</button>
						</li>
						<li>
							<button class="menu-item formsubmit" type="button"
								data-action="product-feeds/feeds/rotate-token"
								data-param="feedId" data-value="{{ feed.id }}"
								data-confirm="{{ 'feed.rotateTokenConfirm'|t('product-feeds') }}">
								{{ 'feed.rotateToken'|t('product-feeds') }}
							</button>
						</li>
					{% endif %}
				</ul>
			</div>
		{% endif %}
	</div>
{% endblock %}

{% block content %}
	{% if not readOnly %}
		<input type="hidden" name="action" value="product-feeds/feeds/save">
		{{ redirectInput('product-feeds/{id}') }}
		{% if feed.id %}<input type="hidden" name="feedId" value="{{ feed.id }}">{% endif %}
	{% endif %}
	<input type="hidden" id="siteId" name="siteId" value="{{ site.id }}">

	<div id="settings">
		{{ forms.lightswitchField({
			first: true,
			label: 'feed.enabledLabel'|t('product-feeds'),
			id: 'enabled',
			name: 'enabled',
			on: feed.enabled,
			disabled: readOnly,
		}) }}

		{{ forms.textField({
			label: 'feed.nameLabel'|t('product-feeds'),
			id: 'name',
			name: 'name',
			value: feed.name,
			errors: feed.getErrors('name'),
			required: true,
			disabled: readOnly,
		}) }}

		{{ forms.textField({
			label: 'feed.handleLabel'|t('product-feeds'),
			id: 'handle',
			name: 'handle',
			class: 'code',
			autocorrect: false,
			autocapitalize: false,
			value: feed.handle,
			errors: feed.getErrors('handle'),
			data: { 'error-key': 'handle' },
			required: true,
			disabled: readOnly,
		}) }}

		{{ forms.selectField({
			label: 'feed.platformLabel'|t('product-feeds'),
			id: 'platform',
			name: 'platform',
			options: platformOptions,
			value: feed.platform,
			disabled: readOnly,
		}) }}

		{{ forms.selectField({
			label: 'feed.sourceLabel'|t('product-feeds'),
			instructions: 'feed.sourceInstructions'|t('product-feeds'),
			id: 'source',
			name: 'source',
			options: sourceOptions,
			value: feed.source,
			disabled: readOnly,
		}) }}

		<div id="source-ids">
			{% include 'product-feeds/_includes/source-ids' %}
		</div>

		{% if filterCondition %}
			{{ forms.field({
				label: 'feed.filterLabel'|t('product-feeds'),
				instructions: 'feed.filterInstructions'|t('product-feeds'),
				id: 'feed-filter',
			}, filterCondition.getBuilderHtml()) }}
		{% endif %}

		<div id="image-transform">
			{{ forms.selectField({
				label: 'feed.imageEngineLabel'|t('product-feeds'),
				instructions: 'feed.imageTransformInstructions'|t('product-feeds'),
				id: 'imageEngine',
				name: 'imageEngine',
				options: imageEngineOptions,
				value: feed.imageEngine,
				disabled: readOnly,
			}) }}

			{% set imageSizeNote = spec.imageSizeNote() %}
			{% if imageSizeNote %}
				<p class="light">{{ imageSizeNote|t('product-feeds') }}</p>
			{% endif %}

			<div id="image-craft-transform" class="{{ feed.imageEngine != 'craft' ? 'hidden' }}">
				{{ forms.selectField({
					label: 'feed.craftTransformLabel'|t('product-feeds'),
					id: 'imageTransform',
					name: 'imageTransform',
					options: craftTransformOptions,
					value: feed.imageTransform,
					disabled: readOnly,
				}) }}
			</div>

			<div id="image-size" class="{{ hideImageSize ? 'hidden' }}">
				<div class="flex">
					{{ forms.textField({
						label: 'feed.imageWidthLabel'|t('product-feeds'),
						id: 'imageWidth',
						name: 'imageWidth',
						type: 'number',
						size: 6,
						value: feed.imageWidth,
						disabled: readOnly,
					}) }}
					{{ forms.textField({
						label: 'feed.imageHeightLabel'|t('product-feeds'),
						id: 'imageHeight',
						name: 'imageHeight',
						type: 'number',
						size: 6,
						value: feed.imageHeight,
						disabled: readOnly,
					}) }}
					{{ forms.selectField({
						label: 'feed.imageFitLabel'|t('product-feeds'),
						id: 'imageFit',
						name: 'imageFit',
						options: imageFitOptions,
						value: feed.imageFit,
						disabled: readOnly,
					}) }}
				</div>
			</div>

			{% if feed.siteId and canBuild %}
				<div id="image-test" class="{{ feed.imageEngine == 'none' ? 'hidden' }}">
					<button id="test-image" type="button" class="btn" data-image-attribute="{{ imageAttribute }}" data-feed-id="{{ feed.id }}">{{ 'imageTest.button'|t('product-feeds') }}</button>
					<div id="image-test-output"></div>
				</div>
			{% endif %}
		</div>

		{% if feedUrl %}
			{{ forms.copytextField({
				label: 'feed.urlLabel'|t('product-feeds'),
				instructions: 'feed.urlInstructions'|t('product-feeds'),
				id: 'feedUrl',
				value: feedUrl,
				tip: feedUrlTip,
				warning: feedUrlWarning,
			}) }}
		{% endif %}
	</div>

	<div id="mapping" class="hidden">
		{% if unmappedRequired %}
			<p class="warning has-icon">
				<span class="icon" aria-hidden="true"></span>
				<span class="visually-hidden">{{ 'Warning:'|t('app') }}</span>
				<span>{{ 'error.requiredAttributesUnmapped'|t('product-feeds', { attributes: unmappedRequired|join(', ') }) }}</span>
			</p>
		{% endif %}

		{% for error in feed.getErrors('fieldMapping') %}
			<p class="error">{{ error }}</p>
		{% endfor %}

		<table class="data fullwidth pf-mapping-table">
			<thead>
				<tr>
					<th scope="col">{{ 'mapping.attributeColumn'|t('product-feeds') }}</th>
					<th scope="col">{{ 'mapping.sourceColumn'|t('product-feeds') }}</th>
					<th scope="col">{{ 'mapping.defaultColumn'|t('product-feeds') }}</th>
					<th scope="col">{{ 'mapping.dataIssuesColumn'|t('product-feeds') }}</th>
				</tr>
			</thead>
			<tbody>
				{% for row in mappingRows %}
					<tr>
						<th scope="row">
							<code>{{ row.name }}</code>
							{% if row.required %}<span class="required" aria-hidden="true"></span>{% endif %}
							{% if row.note %}<span class="info">{{ row.note|t('product-feeds') }}</span>{% endif %}

							{% if row.docUrl %}
								<div class="instructions pf-attribute-doc">
									<a class="go" href="{{ row.docUrl }}" target="_blank" rel="noopener">
										{{ 'mapping.docLink'|t('product-feeds', { platform: feed.getPlatform().label() }) }}
									</a>
								</div>
							{% endif %}
						</th>
						<td>
							{{ forms.select({
								name: 'fieldMapping[' ~ row.name ~ '][source]',
								options: row.sourceOptions,
								value: row.source,
								disabled: readOnly,
							}) }}
						</td>
						<td>
							{% if row.defaultKind == 'none' %}
								<span class="light">-</span>
							{% elseif row.defaultKind == 'image' %}
								{{ forms.elementSelect({
									name: 'fieldMapping[' ~ row.name ~ '][default]',
									elementType: 'craft\\elements\\Asset',
									selectionLabel: 'mapping.chooseDefaultImage'|t('product-feeds'),
									criteria: { kind: 'image' },
									limit: 1,
									elements: defaultImage ? [defaultImage] : [],
									disabled: readOnly,
								}) }}
							{% elseif row.defaultKind == 'select' %}
								{{ forms.select({
									name: 'fieldMapping[' ~ row.name ~ '][default]',
									options: row.defaultOptions,
									value: row.default,
									disabled: readOnly,
								}) }}
							{% else %}
								{{ forms.text({
									name: 'fieldMapping[' ~ row.name ~ '][default]',
									value: row.default,
									disabled: readOnly,
								}) }}
							{% endif %}
						</td>
						<td>
							{% if row.blanks %}
								<div class="error">{{ 'mapping.blankItems'|t('product-feeds', { n: row.blanks }) }}</div>
							{% endif %}
							{% if row.invalid %}
								<div class="warning">{{ 'mapping.nonPositivePrice'|t('product-feeds', { n: row.invalid }) }}</div>
							{% endif %}
							{% if not row.blanks and not row.invalid %}
								{% if row.setOnAllItems %}
									<div class="success">{{ 'mapping.setOnAllItems'|t('product-feeds', { n: row.setOnAllItems }) }}</div>
								{% else %}
									<span class="light">-</span>
								{% endif %}
							{% endif %}
						</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>

		{% set mappingNote = spec.mappingNote() %}
		{% if mappingNote %}
			<p class="light">{{ mappingNote|t('product-feeds') }}</p>
		{% endif %}

		{% include 'product-feeds/_includes/excluded-products' %}

		<hr>

		<h2>{{ 'preview.heading'|t('product-feeds') }}</h2>

		{% if feed.id and canBuild %}
			<p class="light">{{ 'preview.instructions'|t('product-feeds') }}</p>
			<button id="preview-feed" type="button" class="btn" data-feed-id="{{ feed.id }}">{{ 'preview.button'|t('product-feeds') }}</button>
			<div id="preview-output"></div>
		{% else %}
			<p class="notice has-icon">
				<span class="icon" aria-hidden="true"></span>
				<span>{{ 'preview.saveFirst'|t('product-feeds') }}</span>
			</p>
		{% endif %}
	</div>

	{% include 'product-feeds/_includes/plugin-footer' %}
{% endblock %}
